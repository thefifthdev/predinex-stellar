# Predinex Web Application Environment Configuration
# Copy this file to .env.local and update the values as needed

# =============================================================================
# REQUIRED VARIABLES
# =============================================================================

# Network selection - must be either 'mainnet' or 'testnet'
# This determines which network the app connects to
NEXT_PUBLIC_NETWORK=testnet

# =============================================================================
# OPTIONAL VARIABLES
# =============================================================================

# Application URL - used for WalletConnect metadata and OG images
# Defaults to https://predinex.app if not set
NEXT_PUBLIC_APP_URL=http://localhost:3000

# WalletConnect Cloud Project ID
# Required for WalletConnect integration
# Get yours at: https://cloud.walletconnect.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=YOUR_PROJECT_ID

# Stacks API URL - overrides the default API endpoint for the selected network
# Defaults: mainnet=https://api.hiro.so, testnet=https://api.testnet.hiro.so
NEXT_PUBLIC_STACKS_API_URL=https://api.testnet.hiro.so

# Contract Configuration - overrides the default contract for the selected network
# These are typically set via the analytics config, but can be overridden here
NEXT_PUBLIC_CONTRACT_ADDRESS=ST1PQHQKV0RJXZFY1DGX8MNSNYVE3VGZJSRTPGZGM
NEXT_PUBLIC_CONTRACT_NAME=predinex-pool

# Soroban Contract ID - the deployed Soroban contract on Stellar (C... strkey format)
# Required for the Soroban event service (activity feed)
# Testnet example: CAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAD2KM
NEXT_PUBLIC_SOROBAN_CONTRACT_ID=

# =============================================================================
# DEVELOPMENT ONLY
# =============================================================================

# Enable debug logging in development
# Set to 'true' to see detailed logs
DEBUG=false
